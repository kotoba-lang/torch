{:paths ["src"]
 ;; Zero third-party runtime deps — every namespace is portable .cljc (JVM, CLJS, SCI).
 ;; A neural-network module IS data ({layer args} maps, JSONLogic-shaped) — the
 ;; library propagates shapes and counts parameters; it never runs tensor math
 ;; (real execution is a host-injected IBackend port).
 :deps {org.clojure/data.json {:mvn/version "2.5.1"}
        io.github.kotoba-lang/dsl-core
        {:git/sha "9bedd2b9d05133a2d9b0656a55135f142ab11a36"}
        ;; Includes differentiable NCHW convolution, GroupNorm, SiLU,
        ;; multi-head attention, typed Metal tensors, UNet autograd, and a
        ;; real-Metal async twin of multi-head attention (num.tensor-async).
        io.github.kotoba-lang/num
        {:git/sha "7af148a681d517d242b99f97e63b465252cb4fc8"}}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
       :deno-autocast-verify
       {:extra-paths ["test"]
        :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}
        :main-opts ["-m" "cljs.main"
                    "-co" "{:optimizations :simple :target :nodejs :main torch.deno-autocast-verify :output-to \"target/deno-autocast-verify.cjs\"}"
                    "-c" "torch.deno-autocast-verify"]}
       :deno-metal-train-verify
       {:extra-paths ["test"]
        :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}
        :main-opts ["-m" "cljs.main"
                    "-co" "{:optimizations :simple :target :nodejs :main torch.deno-metal-train-verify :output-to \"target/deno-metal-train-verify.cjs\"}"
                    "-c" "torch.deno-metal-train-verify"]}
       :cljs-learned-attention-verify
       {:extra-paths ["test"]
        :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}
        :main-opts ["-m" "cljs.main"
                    "-co" "{:optimizations :simple :target :nodejs :main torch.learned-attention-verify :output-to \"target/learned-attention-verify.cjs\"}"
                    "-c" "torch.learned-attention-verify"]}
       :deno-metal-attention-verify
       {:extra-paths ["test"]
        :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}
        :main-opts ["-m" "cljs.main"
                    "-co" "{:optimizations :simple :target :nodejs :main torch.deno-metal-attention-verify :output-to \"target/deno-metal-attention-verify.cjs\"}"
                    "-c" "torch.deno-metal-attention-verify"]}
       :deno-kv-cache-verify
       {:extra-paths ["test"]
        :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}
        :main-opts ["-m" "cljs.main"
                    "-co" "{:optimizations :simple :target :nodejs :main torch.deno-kv-cache-verify :output-to \"target/deno-kv-cache-verify.cjs\"}"
                    "-c" "torch.deno-kv-cache-verify"]}
       ;; clj-kondo as a Clojars lib (no Homebrew/system install needed).
       :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                     "--fail-level" "error"]}}}
