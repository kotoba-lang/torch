{:paths ["src"]
 ;; Zero third-party runtime deps — every namespace is portable .cljc (JVM, CLJS, SCI).
 ;; A neural-network module IS data ({layer args} maps, JSONLogic-shaped) — the
 ;; library propagates shapes and counts parameters; it never runs tensor math
 ;; (real execution is a host-injected IBackend port).
 :deps {org.clojure/data.json {:mvn/version "2.5.1"}
        io.github.kotoba-lang/dsl-core
        {:git/sha "9bedd2b9d05133a2d9b0656a55135f142ab11a36"}
        ;; Includes differentiable NCHW convolution, GroupNorm, SiLU,
        ;; multi-head attention, typed Metal tensors, UNet autograd, and a
        ;; real-Metal async twin of multi-head attention (num.tensor-async).
        io.github.kotoba-lang/num
        {:git/sha "a03c9dbfcf056cff21dfef9fc67012f3fc97444f"}}
 :aliases
 {:public-gguf-verify
       {:extra-paths ["test"]
        :override-deps {io.github.kotoba-lang/num {:local/root "../num"}}
        :main-opts ["-m" "torch.public-gguf-verify"]}
  :gguf-bundle-export
       {:extra-paths ["test"]
        :override-deps {io.github.kotoba-lang/num {:local/root "../num"}}
        :main-opts ["-m" "torch.gguf-bundle-export"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
       :deno-autocast-verify
       {:extra-paths ["test"]
        :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}
        :main-opts ["-m" "cljs.main"
                    "-co" "{:optimizations :simple :target :nodejs :main torch.deno-autocast-verify :output-to \"target/deno-autocast-verify.cjs\"}"
                    "-c" "torch.deno-autocast-verify"]}
       :deno-metal-train-verify
       {:extra-paths ["test"]
        :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}
        :main-opts ["-m" "cljs.main"
                    "-co" "{:optimizations :simple :target :nodejs :main torch.deno-metal-train-verify :output-to \"target/deno-metal-train-verify.cjs\"}"
                    "-c" "torch.deno-metal-train-verify"]}
       :cljs-learned-attention-verify
       {:extra-paths ["test"]
        :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}
        :main-opts ["-m" "cljs.main"
                    "-co" "{:optimizations :simple :target :nodejs :main torch.learned-attention-verify :output-to \"target/learned-attention-verify.cjs\"}"
                    "-c" "torch.learned-attention-verify"]}
       :cljs-tokenizer-verify
       {:extra-paths ["test"]
        :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}
        :main-opts ["-m" "cljs.main"
                    "-co" "{:optimizations :simple :target :nodejs :main torch.tokenizer-verify :output-to \"target/tokenizer-verify.cjs\"}"
                    "-c" "torch.tokenizer-verify"]}
       :deno-metal-attention-verify
       {:extra-paths ["test"]
        :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}
        :main-opts ["-m" "cljs.main"
                    "-co" "{:optimizations :simple :target :nodejs :main torch.deno-metal-attention-verify :output-to \"target/deno-metal-attention-verify.cjs\"}"
                    "-c" "torch.deno-metal-attention-verify"]}
       :deno-kv-cache-verify
       {:extra-paths ["test"]
        :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}
        :main-opts ["-m" "cljs.main"
                    "-co" "{:optimizations :simple :target :nodejs :main torch.deno-kv-cache-verify :output-to \"target/deno-kv-cache-verify.cjs\"}"
                    "-c" "torch.deno-kv-cache-verify"]}
       :deno-paged-llama-verify
       {:extra-paths ["test"]
        ;; The paged Metal primitives are intentionally verified against the
        ;; sibling num checkout until that revision is published and pinned.
        :override-deps {io.github.kotoba-lang/num {:local/root "../num"}}
        :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}
        :main-opts ["-m" "cljs.main"
                    "-co" "{:optimizations :simple :target :nodejs :main torch.deno-paged-llama-verify :output-to \"target/deno-paged-llama-verify.cjs\"}"
                    "-c" "torch.deno-paged-llama-verify"]}
       :deno-continuous-verify
       {:extra-paths ["test"]
        :override-deps {io.github.kotoba-lang/num {:local/root "../num"}}
        :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}
        :main-opts ["-m" "cljs.main"
                    "-co" "{:optimizations :simple :target :nodejs :main torch.deno-continuous-verify :output-to \"target/deno-continuous-verify.cjs\"}"
                    "-c" "torch.deno-continuous-verify"]}
       :deno-paged-batch-llama-verify
       {:extra-paths ["test"]
        :override-deps {io.github.kotoba-lang/num {:local/root "../num"}}
        :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}
        :main-opts ["-m" "cljs.main"
                    "-co" "{:optimizations :simple :target :nodejs :main torch.deno-paged-batch-llama-verify :output-to \"target/deno-paged-batch-llama-verify.cjs\"}"
                    "-c" "torch.deno-paged-batch-llama-verify"]}
       :deno-ollama-http-verify
       {:extra-paths ["test"]
        :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}
        :main-opts ["-m" "cljs.main"
                    "-co" "{:optimizations :simple :target :nodejs :main torch.deno-ollama-http-verify :output-to \"target/deno-ollama-http-verify.cjs\"}"
                    "-c" "torch.deno-ollama-http-verify"]}
       :deno-quantized-llama-benchmark
       {:extra-paths ["test"]
        :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}
        :main-opts ["-m" "cljs.main"
                    "-co" "{:optimizations :simple :target :nodejs :main torch.deno-quantized-llama-benchmark :output-to \"target/deno-quantized-llama-benchmark.cjs\"}"
                    "-c" "torch.deno-quantized-llama-benchmark"]}
       :deno-public-gguf-metal-verify
       {:extra-paths ["test"]
        :override-deps {io.github.kotoba-lang/num {:local/root "../num"}}
        :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}
        :main-opts ["-m" "cljs.main"
                    "-co" "{:optimizations :simple :target :nodejs :main torch.deno-public-gguf-metal-verify :output-to \"target/deno-public-gguf-metal-verify.cjs\"}"
                    "-c" "torch.deno-public-gguf-metal-verify"]}
       :deno-public-gguf-ollama-verify
       {:extra-paths ["test"]
        :override-deps {io.github.kotoba-lang/num {:local/root "../num"}}
        :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}
        :main-opts ["-m" "cljs.main"
                    "-co" "{:optimizations :simple :target :nodejs :main torch.deno-public-gguf-ollama-verify :output-to \"target/deno-public-gguf-ollama-verify.cjs\"}"
                    "-c" "torch.deno-public-gguf-ollama-verify"]}
       ;; clj-kondo as a Clojars lib (no Homebrew/system install needed).
       :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                     "--fail-level" "error"]}}}
